# Required: Vaultwarden instance URL
VAULTWARDEN_URL=https://vault.yourdomain.com

# Required: API credentials
# Get these from: Vaultwarden web UI → Account Settings → Security → API Key
VAULTWARDEN_CLIENT_ID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULTWARDEN_CLIENT_SECRET=your_client_secret_here

# Optional: stable device identifier (UUID). Auto-generated if not set.
# Set this to avoid creating a new "device" in Vaultwarden on every restart.
VAULTWARDEN_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: required for decryption and write operations.
# Without these, list/get tools still work but fields are shown encrypted.
VAULTWARDEN_EMAIL=you@example.com
VAULTWARDEN_MASTER_PASSWORD=your_master_password
